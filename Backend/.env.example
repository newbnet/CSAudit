# Local secrets only — copy to .env (never commit .env).
# Format: KEY=value (one per line). Do not paste the raw Google JSON here.

# JWT_SECRET=at-least-32-chars-for-local-dev
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# Local dev only. On the server, set the HTTPS callback in deploy.env instead (see deploy.env.example).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5010/api/auth/google/callback
# Local dev only. On the production server, set FRONTEND_ORIGIN in repo-root deploy.env only —
# do not leave localhost here or OAuth will redirect users to http://localhost:3010.
# FRONTEND_ORIGIN=http://localhost:3010
# Optional: GOOGLE_ALLOWED_EMAIL_DOMAIN=yourcompany.com
#
# Google-only (hide email/password login and open registration — requires Google OAuth configured above):
# GOOGLE_AUTH_ONLY=true
#
# Optional: GOOGLE_OAUTH_PROMPT=select_account   (always show account picker; omit for fewer prompts when one Google session)
