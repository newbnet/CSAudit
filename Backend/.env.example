# Local secrets only — copy to .env (never commit .env).
# Format: KEY=value (one per line). Do not paste the raw Google JSON here.

# JWT_SECRET=at-least-32-chars-for-local-dev
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5010/api/auth/google/callback
# FRONTEND_ORIGIN=http://localhost:3010
# Optional: GOOGLE_ALLOWED_EMAIL_DOMAIN=yourcompany.com
