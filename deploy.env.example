# Copy to deploy.env and set for your production server.
# DEPLOY_HOST=10.10.10.64
# DEPLOY_USER=root
# DEPLOY_PATH=/local/bin/projects/Cybersecurity
#
# REQUIRED in production: JWT_SECRET (min 32 chars, random string)
# JWT_SECRET=your-random-secret-at-least-32-characters-long
#
# Google OAuth (optional). User must already exist in db.json with the same email.
# Store client secret securely (e.g. Google Secret Manager); never commit real values to git.
#
# PRODUCTION: Put GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, and GOOGLE_OAUTH_REDIRECT_URI HERE
# in deploy.env (not only in Backend/.env with localhost). deploy.env overrides Backend/.env for
# keys it defines — but if redirect URI is ONLY in Backend/.env as http://localhost:5010/...,
# Google redirects the user's browser to LOCALHOST after "Continue", which no app fix can override.
# Use the public HTTPS callback in both deploy.env and Google Cloud Console:
#   https://cod-data.com/api/auth/google/callback
#
# https://developers.google.com/identity/protocols/oauth2/resources/best-practices
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://cod-data.com/api/auth/google/callback
# Public URL of the React app (no trailing slash). Required for correct OAuth return and invite links.
# If this is wrong or left as localhost, production still infers https://your-domain from nginx headers — fix it anyway:
# FRONTEND_ORIGIN=https://cod-data.com
# Optional: restrict sign-in to one email domain (e.g. yourcompany.com)
# GOOGLE_ALLOWED_EMAIL_DOMAIN=
#
# Optional OAuth prompt (Google). Default: omitted — faster re-login if already signed into Google in the browser.
# Set to select_account to always show Google's account picker (shared PCs / multiple Google accounts).
# GOOGLE_OAUTH_PROMPT=select_account
#
# Google-only sign-in (hides email/password on /login; disables open /register without invite):
# Set after Google OAuth vars above are configured. Use plain true / 1 / yes / on (case-insensitive).
# GOOGLE_AUTH_ONLY=true
#
# After editing deploy.env on the server:
#   cd /local/bin/projects/Cybersecurity && pm2 restart ecosystem.production.config.js --update-env && pm2 save
# Verify: startup log shows GOOGLE_AUTH_ONLY=true, and:
#   curl -sS https://cod-data.com/api/auth/google/enabled
# should include "passwordLogin":false and "selfServicePasswordRegister":false.
#
# Invitation registration still works; password there is optional when GOOGLE_AUTH_ONLY is set.
